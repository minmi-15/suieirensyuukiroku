<h1>Admin::Posts#index</h1>
<table class="table">
  <thead>
    <tr>
      <th>id</th>
      <th>title</th>
      <th>content</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @posts.each do |post| %>
      <tr>
        <td><%= post.id %></td>
        <td><%= post.title %></td>
        <td><%= post.content %></td>
        <td>
          <%= link_to "destroy", admin_post_path(post), 
            method: :delete,
            data: { confirm: "本当に削除しますか？"}  %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
