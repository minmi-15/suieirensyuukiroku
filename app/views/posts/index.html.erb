<h1 class="mb-4">練習記録一覧</h1>

<div class="row">
  <% @posts.each do |post| %>
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm p-3">
        <h5 class="card-title">
          <%= link_to post.title, post_path(post), class: "text-decoration-none" %>
        </h5>
      <p class="card-text text-muted"><%= post.content %></p>
      </div>
    </div>
  <% end %>
</div>