<h2>イベントの通知</h2>

<%= form_with url: group_send_event_path(@group), method: :post do |f| %>
  <div>
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :body, "本文" %>
    <%= f.text_area :body %>
  </div>

  <%= f.submit "送信", class: "btn btn-primary" %>
<% end %>