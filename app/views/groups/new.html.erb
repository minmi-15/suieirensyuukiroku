<div class="container" style="max-width: 600px;">
  <div class="bg-white shadow rounded-3 p-4 mt-5">

    <h2 class="text-center mb-3 fw-bold">グループ作成</h2>
    <p class="text-muted text-center mb-4">水泳仲間と交流するためのグループを作成できます。</p>

    <%= form_with model: @group, local: true do |f| %>

      <div class="mb-3">
        <%= f.label :name, "グループ名" %>
        <%= f.text_field :name, class: "form-control", placeholder: "例：平泳ぎ練習会" %>
      </div>

      <div class="mb-3">
        <%= f.label :introduction, "紹介文" %>
        <%= f.text_area :introduction, class: "form-control", placeholder: "例：平泳ぎが好きな人で集まって練習しましょう！" %>
      </div>

      <%= f.submit "作成する", class: "btn btn-primary w-100 mt-3" %>

    <% end %>

    <div class="text-center mt-3">
      <%= link_to "グループ一覧に戻る", groups_path, class: "text-muted" %>
    </div>

  </div>
</div>
